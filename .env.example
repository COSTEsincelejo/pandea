# Pandea Backend — Variables de entorno
# Copia este archivo como .env y personaliza los valores

# Clave secreta para firmar JWT (cámbiala en producción)
SECRET_KEY=pandea-super-secret-cambiame-en-produccion

# Puerto del servidor
PORT=5000

# Modo debug (true/false)
DEBUG=false

# Ruta de la base de datos SQLite
# DB_PATH=./pandea.db
